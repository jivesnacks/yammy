{{ 'section-bento-grid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .bento-grid-{{ section.id }} {
    --bento-grid-gap: {{ section.settings.grid_gap | times: 0.75 | round: 0 }}px;
    --bento-card-background: {{ section.settings.card_background }};
    --bento-card-border-color: {{ section.settings.card_border_color }};
    --bento-card-border-width: {{ section.settings.card_border_width }}px;
    --bento-card-radius: {{ section.settings.card_radius }}px;
    --bento-heading-color: {{ section.settings.heading_color }};
    --bento-accent-color: {{ section.settings.accent_color }};
    --bento-body-color: {{ section.settings.body_color }};
    --bento-media-width: {{ section.settings.desktop_media_width }}%;
    --bento-card-min-height-mobile: 0px;
    --bento-card-min-height-desktop: {{ section.settings.card_min_height_desktop }}px;
    --bento-mobile-image-height: {{ section.settings.mobile_image_height }}px;
    --bento-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --bento-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --bento-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --bento-body-size-desktop: {{ section.settings.body_size_desktop }}px;
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .bento-grid-{{ section.id }} {
      --bento-grid-gap: {{ section.settings.grid_gap }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign columns_desktop = section.settings.columns_desktop | plus: 0
  assign media_width_desktop = section.settings.desktop_media_width | plus: 0
  assign desktop_image_fraction = media_width_desktop | times: 1.0 | divided_by: 100.0 | divided_by: columns_desktop
-%}

<div class="gradient color-{{ section.settings.section_color_scheme }}">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="bento-grid bento-grid-{{ section.id }} isolate">
      {%- if section.blocks.size > 0 -%}
        <div class="bento-grid__items{% if section.settings.columns_desktop == '2' %} bento-grid__items--2-col{% endif %}">
          {%- for block in section.blocks -%}
            {%- liquid
              assign highlighted_heading = block.settings.heading | escape | newline_to_br | replace: '[[', '<span class="bento-grid__heading-accent">' | replace: ']]', '</span>'

              assign mobile_media_first = true
              if block.settings.mobile_media_position == 'text_first'
                assign mobile_media_first = false
              elsif block.settings.mobile_media_position == 'match_desktop'
                if block.settings.desktop_media_position == 'right'
                  assign mobile_media_first = false
                endif
              endif

              assign loading = 'lazy'
              assign fetch_priority = 'auto'
              if section.index == 1 and forloop.first
                assign loading = 'eager'
                assign fetch_priority = 'high'
              endif

              capture sizes
                echo '(min-width: '
                echo settings.page_width
                echo 'px) calc(('
                echo settings.page_width
                echo 'px - 100px) * '
                echo desktop_image_fraction
                echo '), (min-width: 990px) calc((100vw - 100px) * '
                echo desktop_image_fraction
                echo '), calc(100vw - 3rem)'
              endcapture
            -%}

            <article
              class="bento-grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              <div class="bento-grid__card{% if block.settings.desktop_media_position == 'right' %} bento-grid__card--desktop-reversed{% endif %}{% unless mobile_media_first %} bento-grid__card--mobile-reversed{% endunless %}">
                <div class="bento-grid__card-inner">
                  <div class="bento-grid__media-pane">
                    <div class="bento-grid__media media{% if block.settings.image == blank %} placeholder{% endif %}">
                      {%- if block.settings.image != blank -%}
                        {{
                          block.settings.image
                          | image_url: width: 2400
                          | image_tag:
                            widths: '320, 480, 640, 768, 960, 1200, 1600, 2000, 2400',
                            sizes: sizes,
                            loading: loading,
                            fetchpriority: fetch_priority
                        }}
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </div>
                  </div>

                  <div class="bento-grid__content-pane">
                    <div class="bento-grid__content bento-grid__content--align-{{ section.settings.text_alignment }} bento-grid__content--{{ block.settings.content_vertical_alignment }}">
                      {%- if block.settings.heading != blank -%}
                        <h3 class="bento-grid__heading">{{ highlighted_heading }}</h3>
                      {%- endif -%}

                      {%- if block.settings.text != blank -%}
                        <div class="bento-grid__text rte">
                          {{ block.settings.text }}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              </div>
            </article>
          {%- endfor -%}
        </div>
      {%- elsif request.design_mode -%}
        <div class="bento-grid__empty">
          Add a Bento card block to start building the grid.
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bento grid",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 8,
  "settings": [
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "Section color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "default": "2",
      "options": [
        {
          "value": "1",
          "label": "1 column"
        },
        {
          "value": "2",
          "label": "2 columns"
        }
      ]
    },
    {
      "type": "select",
      "id": "desktop_media_width",
      "label": "Desktop image width",
      "default": "50",
      "options": [
        {
          "value": "40",
          "label": "40%"
        },
        {
          "value": "45",
          "label": "45%"
        },
        {
          "value": "50",
          "label": "50%"
        },
        {
          "value": "55",
          "label": "55%"
        },
        {
          "value": "60",
          "label": "60%"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#F6DECD"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border",
      "default": "#5B2944"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#5B2944"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#F96A00"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#5B2944"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "min": 0,
      "max": 8,
      "step": 1,
      "unit": "px",
      "label": "Card border width",
      "default": 2
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Card corner radius",
      "default": 18
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Grid gap",
      "default": 28
    },
    {
      "type": "range",
      "id": "card_min_height_desktop",
      "min": 320,
      "max": 720,
      "step": 20,
      "unit": "px",
      "label": "Desktop card height",
      "default": 500
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "min": 160,
      "max": 420,
      "step": 10,
      "unit": "px",
      "label": "Mobile image height",
      "default": 280
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Mobile heading size",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 32,
      "max": 96,
      "step": 2,
      "unit": "px",
      "label": "Desktop heading size",
      "default": 58
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Mobile body size",
      "default": 18
    },
    {
      "type": "range",
      "id": "body_size_desktop",
      "min": 16,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Desktop body size",
      "default": 24
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Bento card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "The [[texture]]\nyou've been\nmissing",
          "info": "Use line breaks for stacked headlines. Wrap accent text with double brackets, for example [[texture]]."
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Body text",
          "default": "<p>Perfectly chewy, endlessly snackable. Use this space to describe the image and message for each card.</p>"
        },
        {
          "type": "select",
          "id": "desktop_media_position",
          "label": "Desktop image position",
          "default": "left",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ]
        },
        {
          "type": "select",
          "id": "mobile_media_position",
          "label": "Mobile order",
          "default": "image_first",
          "options": [
            {
              "value": "image_first",
              "label": "Image first"
            },
            {
              "value": "text_first",
              "label": "Text first"
            },
            {
              "value": "match_desktop",
              "label": "Match desktop"
            }
          ]
        },
        {
          "type": "select",
          "id": "content_vertical_alignment",
          "label": "Text vertical alignment",
          "default": "space-between",
          "options": [
            {
              "value": "top",
              "label": "Top"
            },
            {
              "value": "middle",
              "label": "Middle"
            },
            {
              "value": "bottom",
              "label": "Bottom"
            },
            {
              "value": "space-between",
              "label": "Space between"
            }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Custom",
      "name": "Bento grid",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "heading": "The [[texture]]\nyou've been\nmissing",
            "text": "<p>Perfectly chewy, endlessly snackable. Our sweet potato sticks aren't crunchy chips or mushy fruit leather. They're the satisfying chew your cravings have been asking for.</p>",
            "desktop_media_position": "left",
            "mobile_media_position": "image_first",
            "content_vertical_alignment": "space-between"
          }
        },
        {
          "type": "item",
          "settings": {
            "heading": "[[Ingredients]]\nyou can\nactually\npronounce",
            "text": "<p>Sweet potatoes + spices. That's it. No \"natural flavors,\" no seed oils, no ingredients you need to Google. Just real food that respects your body and your taste buds.</p>",
            "desktop_media_position": "left",
            "mobile_media_position": "image_first",
            "content_vertical_alignment": "space-between"
          }
        },
        {
          "type": "item",
          "settings": {
            "heading": "[[Flavors]]\nwith stories",
            "text": "<p>Korean BBQ from family gatherings. Snickerdoodle from childhood memories. Toasted Sesame &amp; Seaweed from coastal traditions. Every flavor connects you to something real.</p>",
            "desktop_media_position": "left",
            "mobile_media_position": "image_first",
            "content_vertical_alignment": "space-between"
          }
        },
        {
          "type": "item",
          "settings": {
            "heading": "[[Nutrition]] that\nactually does\nsomething",
            "text": "<p>12 essential vitamins and minerals per serving. Fiber and protein that keep you satisfied for hours. When you're snacking on actual sweet potatoes, you're getting actual nourishment.</p>",
            "desktop_media_position": "left",
            "mobile_media_position": "image_first",
            "content_vertical_alignment": "space-between"
          }
        }
      ]
    }
  ]
}
{% endschema %}
