{{ 'section-comparison-table.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .comparison-table--{{ section.id }} .comparison-table__header-cell:first-child,
    .comparison-table--{{ section.id }} .comparison-table__cell:first-child {
      width: {{ section.settings.feature_column_width }}px;
    }

    .comparison-table--{{ section.id }} .comparison-table__header-cell:not(:first-child),
    .comparison-table--{{ section.id }} .comparison-table__cell:not(:first-child) {
      width: {{ section.settings.column_width }}px;
    }
  }

  .comparison-table--{{ section.id }} .comparison-table__header-cell {
    font-size: {{ section.settings.header_font_size | times: 0.1 }}rem;
  }

  .comparison-table--{{ section.id }} .comparison-table__cell {
    font-size: {{ section.settings.font_size | times: 0.1 }}rem;
  }

  .comparison-table--{{ section.id }} .comparison-table__check,
  .comparison-table--{{ section.id }} .comparison-table__cross {
    width: {{ section.settings.icon_size | times: 0.1 }}rem;
    height: {{ section.settings.icon_size | times: 0.1 }}rem;
  }

  .comparison-table--{{ section.id }} .comparison-table__check svg,
  .comparison-table--{{ section.id }} .comparison-table__cross svg {
    width: {{ section.settings.icon_size | times: 0.06 }}rem;
    height: {{ section.settings.icon_size | times: 0.06 }}rem;
  }
{%- endstyle -%}

<div class="comparison-table comparison-table--{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div
    class="page-width section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    <table class="comparison-table__table" role="table">
      <thead class="comparison-table__thead">
        <tr class="comparison-table__header-row">
          <th class="comparison-table__header-cell" scope="col"></th>
          <th class="comparison-table__header-cell comparison-table__header-cell--brand" scope="col">
            {%- if section.settings.brand_image != blank -%}
              <div class="comparison-table__header-image">
                {{
                  section.settings.brand_image
                  | image_url: width: 400
                  | image_tag:
                    widths: '50, 100, 150, 200, 300, 400',
                    sizes: '(min-width: 750px) 200px, 100px',
                    loading: 'lazy'
                }}
              </div>
            {%- endif -%}
            {{- section.settings.brand_name | escape -}}
          </th>
          <th class="comparison-table__header-cell" scope="col">
            {%- if section.settings.competitor_image != blank -%}
              <div class="comparison-table__header-image">
                {{
                  section.settings.competitor_image
                  | image_url: width: 400
                  | image_tag:
                    widths: '50, 100, 150, 200, 300, 400',
                    sizes: '(min-width: 750px) 200px, 100px',
                    loading: 'lazy'
                }}
              </div>
            {%- endif -%}
            {{- section.settings.competitor_name | escape -}}
          </th>
        </tr>
      </thead>
      <tbody class="comparison-table__tbody">
        {%- for block in section.blocks -%}
          <tr class="comparison-table__row" {{ block.shopify_attributes }}>
            <td class="comparison-table__cell">{{ block.settings.feature | escape }}</td>
            <td class="comparison-table__cell">
              {%- case block.settings.brand_value -%}
                {%- when 'yes' -%}
                  <span class="comparison-table__check" aria-label="{{ 'accessibility.yes' | t }}">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </span>
                {%- when 'no' -%}
                  <span class="comparison-table__cross" aria-label="{{ 'accessibility.no' | t }}">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </span>
                {%- when 'custom' -%}
                  {{ block.settings.brand_custom_text | escape }}
              {%- endcase -%}
            </td>
            <td class="comparison-table__cell">
              {%- case block.settings.competitor_value -%}
                {%- when 'yes' -%}
                  <span class="comparison-table__check" aria-label="{{ 'accessibility.yes' | t }}">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </span>
                {%- when 'no' -%}
                  <span class="comparison-table__cross" aria-label="{{ 'accessibility.no' | t }}">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </span>
                {%- when 'custom' -%}
                  {{ block.settings.competitor_custom_text | escape }}
              {%- endcase -%}
            </td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  </div>
</div>

{% schema %}
{
  "name": "Comparison table",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "brand_image",
      "label": "Brand image"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "Yammy"
    },
    {
      "type": "image_picker",
      "id": "competitor_image",
      "label": "Competitor image"
    },
    {
      "type": "text",
      "id": "competitor_name",
      "label": "Competitor name",
      "default": "Competitor"
    },
    {
      "type": "range",
      "id": "feature_column_width",
      "min": 150,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Feature column width (desktop)",
      "default": 300
    },
    {
      "type": "range",
      "id": "column_width",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Value column width (desktop)",
      "default": 200
    },
    {
      "type": "range",
      "id": "header_font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Header font size",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 24
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature name",
          "default": "Feature"
        },
        {
          "type": "select",
          "id": "brand_value",
          "label": "Brand value",
          "options": [
            { "value": "yes", "label": "Yes (checkmark)" },
            { "value": "no", "label": "No (cross)" },
            { "value": "custom", "label": "Custom text" }
          ],
          "default": "yes"
        },
        {
          "type": "text",
          "id": "brand_custom_text",
          "label": "Brand custom text"
        },
        {
          "type": "select",
          "id": "competitor_value",
          "label": "Competitor value",
          "options": [
            { "value": "yes", "label": "Yes (checkmark)" },
            { "value": "no", "label": "No (cross)" },
            { "value": "custom", "label": "Custom text" }
          ],
          "default": "no"
        },
        {
          "type": "text",
          "id": "competitor_custom_text",
          "label": "Competitor custom text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison table",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "feature": "All-natural ingredients",
            "brand_value": "yes",
            "competitor_value": "no"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature": "No added sugar",
            "brand_value": "yes",
            "competitor_value": "no"
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature": "Sustainably sourced",
            "brand_value": "yes",
            "competitor_value": "no"
          }
        }
      ]
    }
  ]
}
{% endschema %}
