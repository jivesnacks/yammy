{% doc %}
  @prompt
    In the Image Banner section, add a small "1,000+ reviews" callout text underneath the "Shop Now" button. It should be styled subtly — small font, light color to contrast against the banner — and sit directly below the button within the same button/CTA area.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-callout-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-reviews-callout-text-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
    margin-top: {{ block.settings.spacing_top }}px;
    text-align: center;
    opacity: {{ block.settings.opacity | divided_by: 100.0 }};
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: 0.5px;
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-callout-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<reviews-callout-{{ ai_gen_id }} class="ai-reviews-callout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <span class="ai-reviews-callout-text-{{ ai_gen_id }}">
    {{ block.settings.callout_text }}
  </span>
</reviews-callout-{{ ai_gen_id }}>

<script>
  (function() {
    class ReviewsCallout{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('reviews-callout-{{ ai_gen_id }}', ReviewsCallout{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Reviews callout",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "callout_text",
      "label": "Callout text",
      "default": "1,000+ reviews"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "opacity",
      "label": "Opacity",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 70
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Spacing above",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Reviews callout"
    }
  ]
}
{% endschema %}
