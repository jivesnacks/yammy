{% doc %}
  @prompt
    a bento grid
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bento-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bento-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, {{ block.settings.row_height }}px);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-bento-grid__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.item_border_radius }}px;
    background-color: {{ block.settings.item_background_color }};
    border: {{ block.settings.item_border_thickness }}px solid {{ block.settings.item_border_color }};
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: {{ block.settings.item_padding }}px;
  }

  .ai-bento-grid__item-{{ ai_gen_id }}--1 {
    grid-column: span 2;
    grid-row: span 2;
  }

  .ai-bento-grid__item-{{ ai_gen_id }}--2 {
    grid-column: span 2;
    grid-row: span 1;
  }

  .ai-bento-grid__item-{{ ai_gen_id }}--3 {
    grid-column: span 2;
    grid-row: span 1;
  }

  .ai-bento-grid__item-{{ ai_gen_id }}--4 {
    grid-column: span 1;
    grid-row: span 1;
  }

  .ai-bento-grid__item-{{ ai_gen_id }}--5 {
    grid-column: span 1;
    grid-row: span 1;
  }

  .ai-bento-grid__item-{{ ai_gen_id }}--6 {
    grid-column: span 2;
    grid-row: span 1;
  }

  .ai-bento-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .ai-bento-grid__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .ai-bento-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-bento-grid__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    color: {{ block.settings.text_color }};
  }

  .ai-bento-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 8px 0;
    line-height: 1.2;
  }

  .ai-bento-grid__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    line-height: 1.4;
    opacity: 0.9;
  }

  .ai-bento-grid__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, {{ block.settings.overlay_color }}, transparent);
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-bento-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .ai-bento-grid__item-{{ ai_gen_id }}--1,
    .ai-bento-grid__item-{{ ai_gen_id }}--2,
    .ai-bento-grid__item-{{ ai_gen_id }}--3,
    .ai-bento-grid__item-{{ ai_gen_id }}--4,
    .ai-bento-grid__item-{{ ai_gen_id }}--5,
    .ai-bento-grid__item-{{ ai_gen_id }}--6 {
      grid-column: span 1;
      grid-row: span 1;
      min-height: {{ block.settings.mobile_min_height }}px;
    }

    .ai-bento-grid__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-bento-grid__description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-bento-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bento-grid__container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign image_key = 'item_' | append: i | append: '_image'
        assign title_key = 'item_' | append: i | append: '_title'
        assign description_key = 'item_' | append: i | append: '_description'
        
        assign item_image = block.settings[image_key]
        assign item_title = block.settings[title_key]
        assign item_description = block.settings[description_key]
      %}
      
      <div class="ai-bento-grid__item-{{ ai_gen_id }} ai-bento-grid__item-{{ ai_gen_id }}--{{ i }}">
        {% if item_image %}
          <img
            src="{{ item_image | image_url: width: 1000 }}"
            alt="{{ item_image.alt | escape }}"
            loading="lazy"
            width="{{ item_image.width }}"
            height="{{ item_image.height }}"
            class="ai-bento-grid__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-bento-grid__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        
        <div class="ai-bento-grid__overlay-{{ ai_gen_id }}"></div>
        
        <div class="ai-bento-grid__content-{{ ai_gen_id }}">
          {% if item_title != blank %}
            <h3 class="ai-bento-grid__title-{{ ai_gen_id }}">{{ item_title }}</h3>
          {% endif %}
          {% if item_description != blank %}
            <p class="ai-bento-grid__description-{{ ai_gen_id }}">{{ item_description }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

