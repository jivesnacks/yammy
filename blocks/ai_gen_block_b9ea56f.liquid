{% doc %}
  @prompt
    A 5 column comparison table
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow-x: auto;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-comparison-table__wrapper-{{ ai_gen_id }} {
    min-width: 600px;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    border-spacing: 0;
  }

  .ai-comparison-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_bg_color }};
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_text_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    width: 25%;
  }

  .ai-comparison-table__row-{{ ai_gen_id }} {
    background-color: {{ block.settings.row_bg_color }};
  }

  .ai-comparison-table__row-{{ ai_gen_id }}:nth-child(even) {
    background-color: {{ block.settings.row_alt_bg_color }};
  }

  .ai-comparison-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-size: {{ block.settings.cell_font_size }}px;
    color: {{ block.settings.cell_text_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    font-weight: 600;
    color: {{ block.settings.feature_text_color }};
  }

  .ai-comparison-table__icon-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ai-comparison-table__icon-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-comparison-table__checkmark-{{ ai_gen_id }} {
    color: {{ block.settings.checkmark_color }};
  }

  .ai-comparison-table__cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-table-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.5 }}px;
    }

    .ai-comparison-table__header-cell-{{ ai_gen_id }},
    .ai-comparison-table__cell-{{ ai_gen_id }} {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: {{ block.settings.cell_font_size | times: 0.9 }}px;
    }

    .ai-comparison-table__header-cell-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<comparison-table-{{ ai_gen_id }} class="ai-comparison-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-comparison-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-comparison-table__table-{{ ai_gen_id }}">
      <thead class="ai-comparison-table__header-{{ ai_gen_id }}">
        <tr>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">{{ block.settings.feature_column_label }}</th>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">{{ block.settings.column_1_label }}</th>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">{{ block.settings.column_2_label }}</th>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">{{ block.settings.column_3_label }}</th>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">{{ block.settings.column_4_label }}</th>
        </tr>
      </thead>
      <tbody>
        {% for i in (1..10) %}
          {% liquid
            assign feature_key = 'feature_' | append: i
            assign feature_name = block.settings[feature_key]
          %}

          {% if feature_name != blank %}
            <tr class="ai-comparison-table__row-{{ ai_gen_id }}">
              <td class="ai-comparison-table__cell-{{ ai_gen_id }}">{{ feature_name }}</td>
              {% for col in (1..4) %}
                {% liquid
                  assign col_type_key = 'feature_' | append: i | append: '_col' | append: col
                  assign col_text_key = 'feature_' | append: i | append: '_col' | append: col | append: '_text'
                  assign col_type = block.settings[col_type_key]
                  assign col_text = block.settings[col_text_key]
                %}
                <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
                  {% if col_type == 'yes' %}
                    <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__checkmark-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </span>
                  {% elsif col_type == 'no' %}
                    <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__cross-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  {% elsif col_type == 'custom' %}
                    {{ col_text }}
                  {% endif %}
                </td>
              {% endfor %}
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</comparison-table-{{ ai_gen_id }}>

<script>
  (function() {
    class ComparisonTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupResponsiveScroll();
      }

      setupResponsiveScroll() {
        const wrapper = this.querySelector('.ai-comparison-table__wrapper-{{ ai_gen_id }}');
        if (wrapper && wrapper.scrollWidth > wrapper.clientWidth) {
          this.style.cursor = 'grab';

          let isDown = false;
          let startX;
          let scrollLeft;

          this.addEventListener('mousedown', (e) => {
            isDown = true;
            this.style.cursor = 'grabbing';
            startX = e.pageX - this.offsetLeft;
            scrollLeft = this.scrollLeft;
          });

          this.addEventListener('mouseleave', () => {
            isDown = false;
            this.style.cursor = 'grab';
          });

          this.addEventListener('mouseup', () => {
            isDown = false;
            this.style.cursor = 'grab';
          });

          this.addEventListener('mousemove', (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - this.offsetLeft;
            const walk = (x - startX) * 2;
            this.scrollLeft = scrollLeft - walk;
          });
        }
      }
    }

    customElements.define('comparison-table-{{ ai_gen_id }}', ComparisonTable{{ ai_gen_id }});
  })();
</script>

